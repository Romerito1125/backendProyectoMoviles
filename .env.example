PORT=3000

SUPABASE_URL=https://<project-ref>.supabase.co

# SERVICE ROLE KEY — solo para el backend, nunca exponer al frontend
SUPABASE_SERVICE_ROLE_KEY=

# ANON KEY — para operaciones públicas (opcional)
# SUPABASE_ANON_KEY=

# URL a la que Supabase redirige al usuario tras aceptar la invitación
# Desarrollo local:  http://localhost:8100/set-password
# Red local/celular: http://<IP_LOCAL>:8100/set-password
# Producción:        io.ionic.starter://set-password
INVITE_REDIRECT_URL=http://localhost:8100/set-password

# Clave de 32 bytes (256 bits) para AES-256
ENCRYPTION_KEY=
